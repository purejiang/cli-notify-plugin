{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/session-start?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/user-prompt?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/pre-tool-use?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/post-tool-use?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/permission-request?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/stop?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/session-end?token=PAIRING_KEY"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "http",
            "url": "http://your-vps:8765/hook/notification?token=PAIRING_KEY"
          }
        ]
      }
    ]
